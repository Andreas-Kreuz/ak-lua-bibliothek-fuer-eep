{
  "name": "@ak/web-app",
  "private": true,
  "version": "0.13.2",
  "type": "commonjs",
  "homepage": ".",
  "scripts": {
    "build-shared": "yarn workspace @ak/web-shared run build",
    "dev": "yarn run build-shared && yarn vite --host",
    "build": "yarn run build-shared && yarn vite build && yarn run version",
    "preview": "vite preview",
    "start-server-for-playing": "yarn workspace @ak/web-server run start",
    "start-playing": "concurrently -k \"yarn run start-server-for-playing\" \"yarn run dev\"",
    "start-server-electron": "yarn workspace @ak/web-server run start-e2e-electron",
    "start-server-headless": "yarn workspace @ak/web-server run start-e2e-headless",
    "cy-tests": "concurrently -k \"yarn run start-server-electron\" \"yarn run preview\" \"cypress open\"",
    "cy-tests-run-gui": "concurrently -k \"yarn run start-server-electron\" \"yarn run preview\" \"cypress run --headed\"",
    "cy-tests-run-log": "concurrently -k \"yarn run start-server-electron\" \"yarn run preview\" \"cypress run --headed --spec cypress/e2e/modules/log/log_spec.cy.ts\"",
    "cy-tests-run-headless": "concurrently -k \"yarn run start-server-headless\" \"cypress run --config baseUrl=http://localhost:4173\"",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "version": "echo $npm_package_version > VERSION"
  },
  "dependencies": {
    "@ak/web-shared": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/anek-latin": "^4.5.6",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "@testing-library/dom": "^10.4.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-qr-code": "^2.0.15",
    "react-router-dom": "^7.4.1",
    "socket.io-client": "^4.8.1",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cypress": "^14.2.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.3"
  }
}
