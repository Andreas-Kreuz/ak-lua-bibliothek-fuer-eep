{
  "name": "@ak/web-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": ".",
  "scripts": {
    "build-shared": "yarn workspace @ak/web-shared run build",
    "dev": "yarn run build-shared && yarn vite --host --configLoader native",
    "build": "node ../../scripts/sync-control-extension-version.mjs && yarn run build-shared && yarn vite build --configLoader native",
    "preview": "vite preview --configLoader native",
    "start-server-for-playing": "yarn workspace @ak/web-server run start",
    "start-playing": "node ./scripts/run-parallel.mjs \"yarn run start-server-for-playing\" \"yarn run dev\"",
    "start-server-electron": "yarn workspace @ak/web-server run start-e2e-electron",
    "start-server-headless": "yarn workspace @ak/web-server run start-e2e-headless",
    "cy-tests": "node ./scripts/run-parallel.mjs \"yarn run start-server-electron\" \"yarn run preview\" \"yarn run cypress:open\"",
    "cy-tests-run-gui": "node ./scripts/run-parallel.mjs \"yarn run start-server-electron\" \"yarn run preview\" \"yarn run cypress:run --headed\"",
    "cy-tests-run-log": "node ./scripts/run-parallel.mjs \"yarn run start-server-electron\" \"yarn run preview\" \"yarn run cypress:run --headed --spec cypress/e2e/modules/log/log_spec.cy.ts\"",
    "cy-tests-run-headless": "node ./scripts/run-parallel.mjs \"yarn run start-server-headless\" \"yarn run cypress:run\"",
    "smoke-tests-run-headless": "node ./scripts/local-headless-smoke.mjs",
    "cypress:open": "node ./scripts/run-cypress.mjs open",
    "cypress:run": "node ./scripts/run-cypress.mjs run",
    "version": "node ../../scripts/sync-control-extension-version.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ak/web-shared": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/anek-latin": "^5.2.7",
    "@fontsource/material-icons": "^5.2.7",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@testing-library/dom": "^10.4.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-themes": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cypress": "^15.12.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
