{
  "name": "@ak/root",
  "private": true,
  "version": "0.13.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "storybook": "yarn workspace @ak/web-app run storybook",
    "start-app": "yarn workspace @ak/web-app run dev",
    "start-playing": "yarn workspace @ak/web-app run start-playing",
    "start-server": "yarn workspace @ak/web-server run start-headless",
    "build": "yarn workspace @ak/web-server run build"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/prettier": "^3.0.0"
  },
  "dependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
